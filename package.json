{
  "name": "docify",
  "version": "1.0.0",
  "description": "Docify — floating desktop tool for PDF, image & OCR conversion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.docify.app",
    "productName": "Docify",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "Docify",
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "extraResources": [
      {
        "from": "../doc-converter-extension/latex_server.py",
        "to": "latex_server.py"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
